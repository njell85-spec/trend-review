# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# PubMed E-utilities (optional but recommended to avoid rate limits)
PUBMED_API_KEY=your-pubmed-api-key-here
PUBMED_EMAIL=your-email@example.com

# Agent Configuration
MAX_PAPERS=50
TOP_N=3
SEARCH_DAYS=30
CACHE_TTL_HOURS=24

# Circuit Breaker
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT_MS=60000

# Retry
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_MS=1000

# Output
OUTPUT_DIR=./output
LOG_LEVEL=info

# Google Drive + Gmail (ENABLE_GMAIL=true 로 활성화, 기본 비활성)
# ENABLE_GMAIL=true
# GOOGLE_CREDENTIALS_PATH=./credentials.json
# GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here
# NOTIFY_EMAIL=recipient@example.com

# GitHub Pages (optional — 누적 아카이브 자동 업데이트)
# GITHUB_TOKEN=ghp_your_token_here
# GITHUB_OWNER=your-github-username
# GITHUB_REPO=your-repo-name

# KakaoTalk 알림은 Claude MCP(PlayMCP)를 통해 발송 — 별도 설정 불필요
