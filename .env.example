# ── 분석 LLM 인증 (둘 중 하나 필요 — REPORT_SPEC §4-C) ─────────────────────
# 1순위: claude CLI(구독) — 로컬에서 `claude setup-token`으로 발급, API 과금 없음
# CLAUDE_CODE_OAUTH_TOKEN=your-oauth-token
# 2순위(폴백): Anthropic API — CLI 미설치/세션 한도 시 사용, 과금 발생
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# 분석 모델 재정의 (기본: claude-opus-4-8)
# ANALYSIS_MODEL=claude-opus-4-8

# PubMed E-utilities (선택 — 레이트리밋 완화)
PUBMED_API_KEY=your-pubmed-api-key-here
PUBMED_EMAIL=your-email@example.com

# ── 스크리닝·선정 규격 (REPORT_SPEC §1 확정값 — 임의 변경 금지) ───────────────
MAX_PAPERS=300
TOP_N=1
SEARCH_DAYS=180
CACHE_TTL_HOURS=24

# Circuit Breaker
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT_MS=60000

# Retry
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_MS=1000

# Output
OUTPUT_DIR=./output
LOG_LEVEL=info

# ── 카카오 나챗방 발송 (REPORT_SPEC §4-D — 무인 REST API) ────────────────────
# talk_message 동의로 발급받은 refresh 토큰 필요. 미설정 시 발송만 건너뜀.
# KAKAO_REST_API_KEY=your-kakao-rest-api-key
# KAKAO_REFRESH_TOKEN=your-kakao-refresh-token
# KAKAO_CLIENT_SECRET=your-kakao-client-secret   # 앱에서 client_secret 사용 설정 시

# GitHub Pages (선택 — 누적 아카이브 자동 업데이트)
# GITHUB_TOKEN=ghp_your_token_here
# GITHUB_OWNER=your-github-username
# GITHUB_REPO=your-repo-name

# Google Drive 업로드 (현재 미사용 — phase2/3 연동 대비 보존. ENABLE_DRIVE=true 로만 활성화)
# 이메일(Gmail)은 사용하지 않음 — 알림은 카카오 단일 채널(REPORT_SPEC §4-D).
# ENABLE_DRIVE=true
# GOOGLE_CREDENTIALS_PATH=./credentials.json
# GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here
